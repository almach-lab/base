---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import Layout from "../layouts/Layout.astro";

const generatedSnapshot = readFileSync(
  resolve(process.cwd(), "public/llms.md"),
  "utf-8",
);
const rawLLMs = readFileSync(resolve(process.cwd(), "../../llms.txt"), "utf-8");

const generatedLines = generatedSnapshot.split("\n").length;
const rawLines = rawLLMs.split("\n").length;
---

<Layout title="For LLMs" currentPath="/llms">
  <div class="mx-auto max-w-7xl space-y-6 px-4 py-10 md:px-8">
    <div class="space-y-2 border-b border-border/70 pb-6">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-primary">LLM Reference</p>
      <h1 class="text-3xl font-semibold tracking-tight">Generated UI API Snapshot</h1>
      <p class="max-w-3xl text-sm text-muted-foreground">
        Primary source for LLM usage is generated from <code>packages/ui/src/index.ts</code> and docs metadata.
        Raw <code>llms.txt</code> remains available as a secondary, long-form reference.
      </p>
      <p class="text-xs text-muted-foreground">
        Generated snapshot: {generatedLines.toLocaleString()} lines · Raw llms.txt: {rawLines.toLocaleString()} lines
      </p>
      <div class="flex flex-wrap gap-3 pt-2">
        <a href="/llms.md" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:opacity-90">
          Open Generated Snapshot
        </a>

      </div>
    </div>

    <section class="overflow-hidden rounded-xl border border-border/70 bg-card/40">
      <div class="border-b border-border/70 bg-muted/25 px-4 py-2 text-xs font-medium text-muted-foreground">
        llms.md
      </div>
      <pre class="max-h-[55vh] overflow-y-auto whitespace-pre-wrap wrap-break-word p-5 font-mono text-xs leading-relaxed text-foreground/80">{generatedSnapshot}</pre>
    </section>
  </div>
</Layout>
