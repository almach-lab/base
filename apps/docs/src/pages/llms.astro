---
import Layout from "../layouts/Layout.astro";
import { readFileSync } from "fs";
import { resolve } from "path";

// Read llms.txt from repo root at build time.
// process.cwd() is the app root (/apps/docs) during both dev and SSG build.
const llmsContent = readFileSync(resolve(process.cwd(), "../../llms.txt"), "utf-8");
const lineCount = llmsContent.split("\n").length;
const charCount = llmsContent.length;
---

<Layout title="For LLMs" currentPath="/llms">
  <div class="mx-auto max-w-screen-xl px-4 py-10 md:px-8">

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <div class="mb-8 border-b pb-8">

      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/35 bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
        <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
        </svg>
        LLM Context
      </div>

      <h1 class="mb-2 text-3xl font-bold tracking-tight">llms.txt</h1>
      <p class="mb-1 text-muted-foreground">
        Complete API reference for Almach — installation, all components, forms, query, and utils.
        Paste directly into any LLM context window.
      </p>
      <p class="mb-6 font-mono text-xs text-muted-foreground/60">
        {lineCount.toLocaleString()} lines · {charCount.toLocaleString()} characters ·
        <a href="/llms.txt" target="_blank" rel="noopener noreferrer" class="text-primary transition-colors hover:underline">
          almach.pages.dev/llms.txt ↗
        </a>
      </p>

      <div class="flex flex-wrap gap-3">
        <!-- Copy button — script below handles the interaction -->
        <button
          id="copy-llms-btn"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-90 disabled:opacity-60"
        >
          <!-- Copy icon -->
          <svg id="copy-icon" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
          </svg>
          <!-- Check icon (hidden by default) -->
          <svg id="check-icon" class="hidden h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
          <span id="copy-label">Copy Markdown</span>
        </button>

        <a
          href="/llms.txt"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent"
        >
          View raw
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- ── Content ──────────────────────────────────────────────────────── -->
    <div class="overflow-hidden rounded-xl border bg-muted/30">
      <!-- Toolbar -->
      <div class="flex items-center justify-between border-b bg-muted/50 px-4 py-2.5">
        <span class="font-mono text-xs text-muted-foreground">llms.txt — Markdown</span>
        <button
          id="copy-llms-btn-2"
          class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-muted-foreground transition-colors hover:bg-background hover:text-foreground"
        >
          <svg id="copy-icon-2" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
          </svg>
          <svg id="check-icon-2" class="hidden h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
          <span id="copy-label-2">Copy</span>
        </button>
      </div>
      <pre
        id="llms-content"
        class="max-h-[70vh] overflow-y-auto whitespace-pre-wrap break-words p-5 font-mono text-xs leading-relaxed text-foreground/75"
      >{llmsContent}</pre>
    </div>

  </div>
</Layout>

<script>
  function setupLLMSPage() {
    const content = document.getElementById("llms-content")?.textContent ?? "";

    async function copyContent(btnId: string, iconId: string, checkId: string, labelId: string) {
      const btn = document.getElementById(btnId);
      const copyIcon = document.getElementById(iconId);
      const checkIcon = document.getElementById(checkId);
      const label = document.getElementById(labelId);
      if (!btn) return;

      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(content);
          copyIcon?.classList.add("hidden");
          checkIcon?.classList.remove("hidden");
          if (label) label.textContent = "Copied!";
          setTimeout(() => {
            copyIcon?.classList.remove("hidden");
            checkIcon?.classList.add("hidden");
            if (label) label.textContent = btnId === "copy-llms-btn" ? "Copy Markdown" : "Copy";
          }, 2000);
        } catch (_) {}
      });
    }

    copyContent("copy-llms-btn", "copy-icon", "check-icon", "copy-label");
    copyContent("copy-llms-btn-2", "copy-icon-2", "check-icon-2", "copy-label-2");
  }

  setupLLMSPage();
  document.addEventListener("astro:after-swap", setupLLMSPage);
</script>
