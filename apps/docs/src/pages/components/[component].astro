---
import Layout from "../../layouts/Layout.astro";
import { AppShell } from "../../components/AppShell";

export function getStaticPaths() {
  const components = [
    "alert", "avatar", "badge", "button", "calendar", "card",
    "carousel", "chart", "checkbox", "collapsible", "command",
    "dialog", "drawer", "dropdown-menu",
    "currency-input",
    "input", "label", "modal", "family-modal", "popover", "progress", "radio",
    "select", "separator", "skeleton", "swipe-actions", "switch", "table", "tabs",
    "tag-input", "textarea", "toast", "tooltip",
  ];
  return components.map((component) => ({ params: { component } }));
}

const { component } = Astro.params;
const title = component
  .split("-")
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(" ");
---

<Layout title={title} currentPath={`/components/${component}`}>
  <AppShell page="component" componentSlug={component} client:only="react" />
</Layout>
