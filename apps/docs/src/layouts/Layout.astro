---
import "../styles/globals.css";
import { ClientRouter } from "astro:transitions";
import { Github, Menu, Palette } from "lucide-react";

import { DocSidebar } from "../components/DocSidebar";
import Logo from "../components/Logo.astro";
import { MobileMoreMenu } from "../components/MobileMoreMenu";
import { OnThisPage } from "../components/OnThisPage";
import { SearchCommand } from "../components/SearchCommand";
import { ThemeCustomizer } from "../components/ThemeCustomizer";
import { ThemeModeToggle } from "../components/ThemeModeToggle";

const {
  title = "Almach",
  description = "Accessible, themeable UI components for React with Tailwind CSS.",
  currentPath = Astro.url.pathname,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://almach.kita.blue";
const canonicalUrl = `${siteUrl}${currentPath}`;
const pageTitle =
  title === "Almach"
    ? "Almach — UI Components for React"
    : `${title} · Almach`;

const topNavItems = [
  { name: "Docs", href: "/getting-started" },
  { name: "Components", href: "/components" },
  { name: "Blocks", href: "/blocks" },
  { name: "Forms", href: "/forms" },
  { name: "Query", href: "/query" },
];

const isHome = currentPath === "/";
const showDocsShell = !isHome;
const iconButtonClass =
  "flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring";
const navLinkBaseClass =
  "rounded-md px-3 py-1.5 text-sm font-medium transition-colors";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Almach" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/og.png`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og.png`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <script is:inline>
      (() => {
        const root = document.documentElement;

        const applyStoredTheme = () => {
          try {
            const storedMode = localStorage.getItem("theme");
            const isDark = storedMode
              ? storedMode === "dark"
              : root.classList.contains("dark");
            root.classList.toggle("dark", isDark);

            const raw = localStorage.getItem("almach-theme");
            if (!raw) {
              window.dispatchEvent(
                new CustomEvent("almach-theme-mode-changed"),
              );
              return;
            }

            const theme = JSON.parse(raw);
            const surface = theme?.surfaceTokens;

            if (surface) {
              root.style.setProperty(
                "--theme-background-light",
                surface.backgroundLight,
              );
              root.style.setProperty(
                "--theme-foreground-light",
                surface.foregroundLight,
              );
              root.style.setProperty("--theme-card-light", surface.cardLight);
              root.style.setProperty(
                "--theme-card-foreground-light",
                surface.cardForegroundLight,
              );
              root.style.setProperty("--theme-muted-light", surface.mutedLight);
              root.style.setProperty(
                "--theme-muted-foreground-light",
                surface.mutedForegroundLight,
              );
              root.style.setProperty(
                "--theme-accent-light",
                surface.accentLight,
              );
              root.style.setProperty(
                "--theme-accent-foreground-light",
                surface.accentForegroundLight,
              );
              root.style.setProperty(
                "--theme-border-light",
                surface.borderLight,
              );
              root.style.setProperty("--theme-input-light", surface.inputLight);
              root.style.setProperty(
                "--theme-secondary-light",
                surface.accentLight,
              );
              root.style.setProperty(
                "--theme-secondary-foreground-light",
                surface.accentForegroundLight,
              );

              root.style.setProperty(
                "--theme-background-dark",
                surface.backgroundDark,
              );
              root.style.setProperty(
                "--theme-foreground-dark",
                surface.foregroundDark,
              );
              root.style.setProperty("--theme-card-dark", surface.cardDark);
              root.style.setProperty(
                "--theme-card-foreground-dark",
                surface.cardForegroundDark,
              );
              root.style.setProperty("--theme-muted-dark", surface.mutedDark);
              root.style.setProperty(
                "--theme-muted-foreground-dark",
                surface.mutedForegroundDark,
              );
              root.style.setProperty("--theme-accent-dark", surface.accentDark);
              root.style.setProperty(
                "--theme-accent-foreground-dark",
                surface.accentForegroundDark,
              );
              root.style.setProperty(
                "--theme-border-dark",
                surface.borderDark,
              );
              root.style.setProperty("--theme-input-dark", surface.inputDark);
              root.style.setProperty(
                "--theme-secondary-dark",
                surface.accentDark,
              );
              root.style.setProperty(
                "--theme-secondary-foreground-dark",
                surface.accentForegroundDark,
              );
            }

            const status = theme?.statusTokens;
            if (status) {
              root.style.setProperty("--theme-success-light", status.successLight);
              root.style.setProperty(
                "--theme-success-foreground-light",
                status.successForegroundLight,
              );
              root.style.setProperty("--theme-warning-light", status.warningLight);
              root.style.setProperty(
                "--theme-warning-foreground-light",
                status.warningForegroundLight,
              );
              root.style.setProperty(
                "--theme-destructive-light",
                status.destructiveLight,
              );
              root.style.setProperty(
                "--theme-destructive-foreground-light",
                status.destructiveForegroundLight,
              );
              root.style.setProperty("--theme-success-dark", status.successDark);
              root.style.setProperty(
                "--theme-success-foreground-dark",
                status.successForegroundDark,
              );
              root.style.setProperty("--theme-warning-dark", status.warningDark);
              root.style.setProperty(
                "--theme-warning-foreground-dark",
                status.warningForegroundDark,
              );
              root.style.setProperty(
                "--theme-destructive-dark",
                status.destructiveDark,
              );
              root.style.setProperty(
                "--theme-destructive-foreground-dark",
                status.destructiveForegroundDark,
              );
            }

            if (theme?.primaryLight) {
              root.style.setProperty("--theme-primary-light", theme.primaryLight);
            }
            if (theme?.primaryDark) {
              root.style.setProperty("--theme-primary-dark", theme.primaryDark);
            }

            const activePrimary = isDark ? theme?.primaryDark : theme?.primaryLight;
            if (activePrimary) {
              root.style.setProperty("--primary", activePrimary);
              root.style.setProperty("--ring", activePrimary);
            }

            if (theme?.radius) {
              root.style.setProperty("--radius", theme.radius);
            }
            if (typeof theme?.overlayMs === "number") {
              root.style.setProperty(
                "--theme-motion-overlay-duration-ms",
                String(theme.overlayMs),
              );
              root.style.setProperty(
                "--theme-motion-overlay-duration",
                `${theme.overlayMs}ms`,
              );
            }
            if (typeof theme?.interactiveMs === "number") {
              root.style.setProperty(
                "--theme-motion-interactive-duration",
                `${theme.interactiveMs}ms`,
              );
            }
            if (theme?.ease) {
              root.style.setProperty("--theme-motion-ease-standard", theme.ease);
            }
          } catch {
            // noop
          }

          window.dispatchEvent(new CustomEvent("almach-theme-mode-changed"));
        };

        if (!window.__almachApplyTheme) {
          window.__almachApplyTheme = applyStoredTheme;
          document.addEventListener("astro:before-swap", window.__almachApplyTheme);
          document.addEventListener("astro:after-swap", window.__almachApplyTheme);
        }

        window.__almachApplyTheme();
      })();
    </script>
  </head>

  <body class="bg-background text-foreground antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="sticky top-0 z-40 border-b border-border/60 bg-background/95 backdrop-blur-xl">
        <div class="mx-auto flex h-14 w-full max-w-400 items-center gap-3 px-4 lg:px-6 xl:px-8">
          <div class="flex items-center gap-2.5 lg:gap-3">
            {showDocsShell && (
              <button
                id="sidebar-toggle"
                class={`${iconButtonClass} lg:hidden`}
                aria-label="Toggle sidebar"
                aria-controls="mobile-sidebar"
                onclick="window.dispatchEvent(new CustomEvent('almach-sidebar-toggle'))"
              >
                <Menu className="h-5 w-5" aria-hidden="true" />
              </button>
            )}

            <a href="/" class="flex items-center gap-2.5" aria-label="Almach homepage">
              <Logo class="h-5.5 w-5.5" />
              <span class="text-base font-semibold tracking-tight">Almach</span>
            </a>
          </div>

          <nav class="hidden items-center gap-0.5 pl-2 lg:flex" aria-label="Main navigation">
            {topNavItems.map((item) => (
              <a
                href={item.href}
                class={`${navLinkBaseClass} ${
                  currentPath === item.href || currentPath.startsWith(`${item.href}/`)
                    ? "bg-accent text-foreground shadow-[inset_0_0_0_1px_hsl(var(--border))]"
                    : "text-muted-foreground hover:bg-accent hover:text-foreground"
                }`}
              >
                {item.name}
              </a>
            ))}
          </nav>

          <div class="ml-auto flex items-center gap-1.5">
            <SearchCommand client:load />

            <div class="hidden items-center gap-1 lg:flex">
              <div class="mx-1.5 h-5 w-px bg-border" aria-hidden="true"></div>

              <button
                id="customizer-toggle"
                class={iconButtonClass}
                aria-label="Open theme customizer"
                onclick="window.dispatchEvent(new CustomEvent('almach-customizer-toggle'))"
              >
                <Palette className="h-5 w-5" aria-hidden="true" />
              </button>

              <a
                href="https://github.com/almach-lab/base"
                target="_blank"
                rel="noopener noreferrer"
                class={iconButtonClass}
                aria-label="GitHub"
              >
                <Github className="h-5 w-5" aria-hidden="true" />
              </a>
            </div>

            <MobileMoreMenu client:load />
          </div>
        </div>
      </header>

      {
        isHome ? (
          <main class="flex-1" id="main-content" transition:name="page-content">
            <slot />
          </main>
        ) : (
          <div class="mx-auto flex w-full max-w-400 flex-1">
            <DocSidebar currentPath={currentPath} client:load />

            <main
              class="min-w-0 flex-1 px-4 py-6 md:px-8 md:py-7 lg:px-10 xl:px-12"
              id="main-content"
              transition:name="page-content"
            >
              <div class="mx-auto w-full max-w-3xl xl:max-w-4xl">
                <slot />
              </div>
            </main>

            <aside class="hidden w-64 shrink-0 border-l border-sidebar-border/60 bg-sidebar/55 px-4 py-8 xl:block">
              <OnThisPage client:load />
            </aside>
          </div>
        )
      }

      <footer class="mt-auto border-t border-border/60">
        <div class="mx-auto flex w-full max-w-400 flex-col items-center justify-between gap-4 px-6 py-6 text-xs text-muted-foreground sm:flex-row">
          <div class="flex items-center gap-2">
            <Logo class="h-4 w-4" />
            Almach · MIT License
          </div>
          <div class="text-center sm:text-right">Built with React · Astro · Tailwind CSS v4</div>
        </div>
      </footer>
    </div>

    <ThemeCustomizer client:load />
  </body>
</html>
