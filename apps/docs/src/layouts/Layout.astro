---
import "../styles/globals.css";
import ClientRouter from "astro/components/ClientRouter.astro";
import { ThemeCustomizer } from "../components/ThemeCustomizer";
import { SearchCommand } from "../components/SearchCommand";
import Logo from "../components/Logo.astro";
import { DOC_COMPONENT_GROUPS } from "../lib/doc-components";
import { ScrollArea } from "@almach/ui";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = "Almach",
  description = "Accessible, themeable UI components for React built on Radix UI and Tailwind CSS.",
  currentPath = Astro.url.pathname,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://almach.kita.blue";
const canonicalUrl = `${siteUrl}${currentPath}`;
const ogImage = `${siteUrl}/og.png`;
const pageTitle = title === "Almach" ? "Almach — UI Components for React" : `${title} · Almach`;
const topNavItems = [
  { name: "Getting Started", href: "/getting-started" },
  { name: "Components", href: "/components" },
  { name: "Forms", href: "/forms" },
  { name: "Query", href: "/query" },
];

const sidebarGroups = [
  {
    title: "Introduction",
    items: [
      { name: "Getting Started", href: "/getting-started" },
      { name: "For LLMs", href: "/llms" },
    ],
  },
  {
    title: "Components",
    items: [
      { name: "Overview", href: "/components" },
    ],
  },
  ...DOC_COMPONENT_GROUPS.map((group) => ({
    title: group.name,
    items: group.items.map((item) => ({
      name: item.name,
      href: `/components/${item.slug}`,
    })),
  })),
  {
    title: "Packages",
    items: [
      { name: "Forms", href: "/forms" },
      { name: "Query", href: "/query" },
    ],
  },
];

const isHome = currentPath === "/";
const isComponentsPage = currentPath === "/components";
const pageAnchors =
  isComponentsPage
    ? DOC_COMPONENT_GROUPS.map((group) => ({ id: `group-${group.name.toLowerCase()}`, name: group.name }))
    : currentPath === "/getting-started"
      ? [
          { id: "step-install", name: "Install packages" },
          { id: "step-styles", name: "Add styles" },
          { id: "step-colors", name: "Customize colors" },
          { id: "step-providers", name: "Wrap with providers" },
          { id: "step-components", name: "Use components" },
          { id: "step-forms", name: "Handle forms" },
        ]
      : currentPath === "/forms"
        ? [
            { id: "forms-demos", name: "Interactive demos" },
            { id: "forms-install", name: "Installation" },
            { id: "forms-quick-start", name: "Quick start" },
            { id: "forms-fields", name: "Field components" },
          ]
        : currentPath === "/query"
          ? [
              { id: "query-demos", name: "Interactive demos" },
              { id: "query-install", name: "Installation" },
              { id: "query-queries", name: "Queries" },
              { id: "query-mutations", name: "Mutations" },
              { id: "query-server-actions", name: "Server actions" },
            ]
          : [];
const showRightRail = !isHome && pageAnchors.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Almach" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Almach — UI Components for React" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />

    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var dark = stored === "dark" || (!stored && prefersDark);
        if (dark) document.documentElement.classList.add("dark");
        try {
          var t = localStorage.getItem("almach-theme");
          if (t) {
            var v = JSON.parse(t);
            var root = document.documentElement;
            var primary = dark ? v.primaryDark : v.primaryLight;
            if (primary) {
              root.style.setProperty("--primary", primary);
              root.style.setProperty("--ring", primary);
            }
            if (v.radius) root.style.setProperty("--radius", v.radius);
          }
        } catch (_) {}
      })();
    </script>
  </head>

  <body class="bg-background text-foreground">
    <div class="flex min-h-screen flex-col bg-background">

      <!-- ── Header ─────────────────────────────────────────────────────── -->
      <header class="sticky top-0 z-40 w-full border-b border-border/70 bg-background/90 backdrop-blur-xl">
        <div class="mx-auto flex h-[3.25rem] max-w-screen-xl items-center gap-2 px-3 sm:px-4 md:px-5">

          <!-- Left: sidebar toggle (mobile, non-home) + logo -->
          <div class="flex shrink-0 items-center gap-2">
            {!isHome && (
              <button
                id="sidebar-toggle"
                class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1 lg:hidden"
                aria-label="Open navigation"
                aria-expanded="false"
                aria-controls="mobile-overlay"
              >
                <!-- Hamburger -->
                <svg class="h-[15px] w-[15px]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <line x1="3" y1="12" x2="21" y2="12"/>
                  <line x1="3" y1="18" x2="15" y2="18"/>
                </svg>
              </button>
            )}

            <a href="/" class="flex items-center gap-2 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1" aria-label="Almach home">
              <Logo class="h-6 w-6 text-foreground" />
              <span class="text-sm font-semibold tracking-tight">Almach</span>
            </a>
          </div>

          <!-- Center: top nav -->
          <nav class="ml-2 hidden items-center gap-1 lg:flex" aria-label="Top navigation">
            {topNavItems.map((item) => (
              <a
                href={item.href}
                class={`rounded-md px-2.5 py-1.5 text-[13px] font-medium transition-colors ${
                  currentPath === item.href || currentPath.startsWith(`${item.href}/`)
                    ? "bg-primary/12 text-primary"
                    : "text-muted-foreground hover:bg-accent/70 hover:text-foreground"
                }`}
                aria-current={currentPath === item.href ? "page" : undefined}
              >
                {item.name}
              </a>
            ))}
          </nav>

          <!-- Right: search + actions -->
          <div class="flex flex-1 items-center justify-end gap-1">

            <!-- Search (icon on mobile, expanded bar on desktop) -->
            <SearchCommand client:only="react" />

            <!-- ── Desktop-only actions ─────────────────────────────────── -->
            <div class="hidden items-center gap-1 lg:flex">
              <div class="mx-1.5 h-4 w-px bg-border" aria-hidden="true"></div>

              <!-- Customize -->
              <button
                id="customizer-toggle"
                class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                aria-label="Customize theme"
                title="Customize theme"
              >
                <svg class="h-[15px] w-[15px]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d="M18.37 2.63 14 7l-1.59-1.59a2 2 0 0 0-2.82 0L8 7l9 9 1.59-1.59a2 2 0 0 0 0-2.82L17 10l4.37-4.37a2.12 2.12 0 1 0-3-3Z"/>
                  <path d="M9 8c-2 3-4 3.5-7 4l8 10c2-1 6-5 6-7"/>
                  <path d="M14.5 17.5 4.5 15"/>
                </svg>
              </button>

              <!-- Theme toggle -->
              <button
                id="theme-toggle"
                class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                aria-label="Switch to dark mode"
                aria-pressed="false"
              >
                <svg id="icon-sun" class="hidden h-[15px] w-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="5"/>
                  <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                  <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                <svg id="icon-moon" class="h-[15px] w-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
              </button>

              <!-- GitHub -->
              <a
                href="https://github.com/almach-lab/base"
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                aria-label="View on GitHub (opens in new tab)"
              >
                <svg class="h-[15px] w-[15px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
            </div>

            <!-- ── Mobile-only: one "more" menu button ─────────────────── -->
            <div class="relative lg:hidden" id="more-menu-wrapper">
              <button
                id="more-btn"
                class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                aria-label="More actions"
                aria-haspopup="menu"
                aria-expanded="false"
                aria-controls="more-dropdown"
              >
                <!-- Three dots / ellipsis -->
                <svg class="h-[15px] w-[15px]" fill="currentColor" viewBox="0 0 20 20">
                  <circle cx="4" cy="10" r="1.5"/>
                  <circle cx="10" cy="10" r="1.5"/>
                  <circle cx="16" cy="10" r="1.5"/>
                </svg>
              </button>

              <!-- Dropdown panel -->
              <div
                id="more-dropdown"
                class="absolute right-0 top-full z-50 mt-1.5 hidden w-52 origin-top-right rounded-xl border bg-background p-1 shadow-lg ring-1 ring-black/5 dark:ring-white/5"
                role="menu"
              >
                <!-- LLMs copy -->
                <button
                  id="llm-copy-btn-mobile"
                  class="flex w-full cursor-pointer items-center gap-3 rounded-lg px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                  role="menuitem"
                >
                  <svg id="llm-copy-icon-m" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                  </svg>
                  <svg id="llm-check-icon-m" class="hidden h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                  <span id="llm-copy-label-m">Copy for LLMs</span>
                </button>

                <div class="my-1 h-px bg-border" role="separator"></div>

                <!-- Customize -->
                <button
                  id="customizer-toggle-mobile"
                  class="flex w-full cursor-pointer items-center gap-3 rounded-lg px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                  role="menuitem"
                >
                  <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <path d="M18.37 2.63 14 7l-1.59-1.59a2 2 0 0 0-2.82 0L8 7l9 9 1.59-1.59a2 2 0 0 0 0-2.82L17 10l4.37-4.37a2.12 2.12 0 1 0-3-3Z"/>
                    <path d="M9 8c-2 3-4 3.5-7 4l8 10c2-1 6-5 6-7"/>
                    <path d="M14.5 17.5 4.5 15"/>
                  </svg>
                  Customize theme
                </button>

                <!-- Theme toggle -->
                <button
                  id="theme-toggle-mobile"
                  class="flex w-full cursor-pointer items-center gap-3 rounded-lg px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                  role="menuitem"
                >
                  <svg id="icon-sun-m" class="hidden h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                  </svg>
                  <svg id="icon-moon-m" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                  </svg>
                  <span id="theme-toggle-label-m">Toggle theme</span>
                </button>

                <div class="my-1 h-px bg-border" role="separator"></div>

                <!-- GitHub -->
                <a
                  href="https://github.com/almach-lab/base"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
                  role="menuitem"
                  aria-label="View on GitHub (opens in new tab)"
                >
                  <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub
                  <svg class="ml-auto h-3 w-3 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
              </div>
            </div>

          </div>
        </div>
      </header>

      <!-- ── Mobile quick links ─────────────────────────────────────────── -->
      {!isHome && (
        <div class="border-b border-border/70 bg-background/95 md:hidden">
          <div class="mx-auto w-full max-w-screen-xl overflow-x-auto px-3 py-2">
            <nav class="flex min-w-max items-center gap-1" aria-label="Quick navigation">
              {topNavItems.map((item) => (
                <a
                  href={item.href}
                  class={`rounded-md px-2.5 py-1.5 text-xs font-medium transition-colors ${
                    currentPath === item.href || currentPath.startsWith(`${item.href}/`)
                      ? "bg-primary/12 text-primary"
                      : "text-muted-foreground hover:bg-accent/70 hover:text-foreground"
                  }`}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.name}
                </a>
              ))}
            </nav>
          </div>
        </div>
      )}

      <!-- ── Mobile sidebar overlay ──────────────────────────────────────── -->
      <div
        id="mobile-overlay"
        class="fixed inset-0 z-50 hidden lg:hidden"
        role="dialog"
        aria-modal="true"
        aria-label="Navigation menu"
      >
        <div id="mobile-backdrop" class="absolute inset-0 bg-background/70 backdrop-blur-sm"></div>

        <aside id="mobile-sidebar" class="absolute inset-y-0 left-0 flex w-72 max-w-[85vw] flex-col border-r border-border/70 bg-background shadow-xl">
          <!-- Sidebar header -->
          <div class="flex h-12 shrink-0 items-center justify-between border-b px-4">
            <a href="/" class="flex items-center gap-2 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1" aria-label="Almach home">
              <Logo class="h-5 w-5 text-foreground" />
              <span class="text-sm font-bold">Almach</span>
            </a>
            <button
              id="sidebar-close"
              class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
              aria-label="Close navigation"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <!-- Nav items -->
          <div class="flex-1 overflow-y-auto px-3 py-4">
            <nav aria-label="Mobile navigation">
              {sidebarGroups.map((group) => (
                <div class="mb-5">
                  <p class="mb-1.5 px-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/60">
                    {group.title}
                  </p>
                  <div class="space-y-0.5">
                    {group.items.map((item) => (
                      <a
                        href={item.href}
                        data-nav-href={item.href}
                        class={`relative flex items-center rounded-md px-3 py-1.5 text-[13px] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1 ${
                          currentPath === item.href
                            ? "bg-primary/12 font-medium text-primary"
                            : "text-muted-foreground hover:bg-accent/70 hover:text-foreground"
                        }`}
                        aria-current={currentPath === item.href ? "page" : undefined}
                      >
                     
                        {item.name}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </nav>
          </div>
        </aside>
      </div>

      <!-- ── Page content ────────────────────────────────────────────────── -->
      {
        isHome ? (
          <main class="flex-1" id="main-content" transition:name="page-content">
            <slot />
          </main>
        ) : (
          <div class="mx-auto flex w-full max-w-[1440px] flex-1">
            <!-- Desktop sidebar -->
            <aside class="hidden w-56 shrink-0 border-r border-border/70 bg-muted/10 xl:block" aria-label="Documentation navigation">
              <div class="sticky top-12 h-[calc(100vh-3rem)] px-2 py-2.5">
                <ScrollArea className="h-full pr-1" client:load>
                  <nav aria-label="Documentation navigation" class="px-1 pb-8">
                    {sidebarGroups.map((group) => (
                      <div class="mb-4">
                        <p class="mb-1.5 px-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/60">
                          {group.title}
                        </p>
                        <div class="space-y-0.5">
                          {group.items.map((item) => (
                            <a
                              href={item.href}
                              data-nav-href={item.href}
                            class={`relative flex items-center rounded-md px-2.5 py-1.5 text-[12px] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1 ${
                                currentPath === item.href
                                  ? "bg-primary/12 font-medium text-primary"
                                  : "text-muted-foreground hover:bg-accent/70 hover:text-foreground"
                              }`}
                              aria-current={currentPath === item.href ? "page" : undefined}
                            >
                              {item.name}
                            </a>
                          ))}
                        </div>
                      </div>
                    ))}
                  </nav>
                </ScrollArea>
              </div>
            </aside>

            <main class="min-w-0 flex-1" id="main-content" transition:name="page-content">
              <div class="mx-auto w-full max-w-4xl px-0 md:px-2 xl:max-w-[70rem] xl:px-3">
                <slot />
              </div>
            </main>

            {
              showRightRail && (
                <aside class="hidden w-52 shrink-0 border-l border-border/70 bg-muted/10 px-2 py-2.5 xl:block" aria-label="On this page">
                  <div class="sticky top-12 h-[calc(100vh-3rem)]">
                    <ScrollArea className="h-full pr-1" client:load>
                      <div class="space-y-6 px-2 pb-8">
                        <div class="space-y-2.5">
                          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">On this page</p>
                          <nav class="space-y-1">
                            {pageAnchors.map((anchor) => (
                              <a
                                href={`#${anchor.id}`}
                                class="block rounded-md px-2 py-1.5 text-[12px] text-muted-foreground transition-colors hover:bg-accent/70 hover:text-foreground"
                              >
                                {anchor.name}
                              </a>
                            ))}
                          </nav>
                        </div>
                      </div>
                    </ScrollArea>
                  </div>
                </aside>
              )
            }
          </div>
        )
      }

      <!-- ── Footer ─────────────────────────────────────────────────────── -->
      <footer class="border-t">
        <div class="mx-auto flex max-w-screen-xl flex-col items-center justify-between gap-2.5 px-4 py-4 text-[11px] text-muted-foreground sm:flex-row md:px-5">
          <div class="flex items-center gap-2">
            <Logo class="h-3.5 w-3.5 text-muted-foreground" />
            <span>Almach · MIT License</span>
          </div>
          <div class="flex items-center gap-4">
            <span>React · Astro · Tailwind CSS v4</span>
            <a
              href="https://github.com/almach-lab/base"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1"
              aria-label="View on GitHub (opens in new tab)"
            >
              GitHub ↗
            </a>
          </div>
        </div>
      </footer>
    </div>

    <ThemeCustomizer client:only="react" />

    <script>
      // ── Helpers ───────────────────────────────────────────────────────────
      function getCustomTheme() {
        try { return JSON.parse(localStorage.getItem("almach-theme") || "null"); }
        catch (_) { return null; }
      }

      function applyCustomTheme(dark: boolean) {
        const t = getCustomTheme();
        if (!t) return;
        const primary = dark ? t.primaryDark : t.primaryLight;
        if (primary) {
          document.documentElement.style.setProperty("--primary", primary);
          document.documentElement.style.setProperty("--ring", primary);
        }
        if (t.radius) document.documentElement.style.setProperty("--radius", t.radius);
      }

      // ── Sync all theme icon states ────────────────────────────────────────
      function syncThemeIcons(dark: boolean) {
        // desktop icons
        document.getElementById("icon-sun")?.classList.toggle("hidden", !dark);
        document.getElementById("icon-moon")?.classList.toggle("hidden", dark);
        // desktop button: aria-pressed + aria-label
        const themeBtn = document.getElementById("theme-toggle");
        if (themeBtn) {
          themeBtn.setAttribute("aria-pressed", String(dark));
          themeBtn.setAttribute("aria-label", dark ? "Switch to light mode" : "Switch to dark mode");
        }
        // mobile dropdown icons
        document.getElementById("icon-sun-m")?.classList.toggle("hidden", !dark);
        document.getElementById("icon-moon-m")?.classList.toggle("hidden", dark);
        // mobile button: aria-label
        const themeBtnM = document.getElementById("theme-toggle-mobile");
        if (themeBtnM) {
          themeBtnM.setAttribute("aria-label", dark ? "Switch to light mode" : "Switch to dark mode");
        }
        const label = document.getElementById("theme-toggle-label-m");
        if (label) label.textContent = dark ? "Light mode" : "Dark mode";
      }

      function toggleTheme() {
        const isDark = document.documentElement.classList.contains("dark");
        const next = !isDark;
        localStorage.setItem("theme", next ? "dark" : "light");
        document.documentElement.classList.toggle("dark", next);
        syncThemeIcons(next);
        applyCustomTheme(next);
        window.dispatchEvent(new CustomEvent("almach-theme-mode-changed"));
      }

      // ── Theme toggle ──────────────────────────────────────────────────────
      function setupThemeToggle() {
        const dark = document.documentElement.classList.contains("dark");
        syncThemeIcons(dark);
        document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
        document.getElementById("theme-toggle-mobile")?.addEventListener("click", () => {
          closeMoreMenu();
          toggleTheme();
        });
      }

      // ── More menu (mobile) ────────────────────────────────────────────────
      function openMoreMenu() {
        const dropdown = document.getElementById("more-dropdown");
        const btn = document.getElementById("more-btn");
        dropdown?.classList.remove("hidden");
        btn?.setAttribute("aria-expanded", "true");
      }

      function closeMoreMenu() {
        const dropdown = document.getElementById("more-dropdown");
        const btn = document.getElementById("more-btn");
        dropdown?.classList.add("hidden");
        btn?.setAttribute("aria-expanded", "false");
      }

      function setupMoreMenu() {
        const btn = document.getElementById("more-btn");
        const wrapper = document.getElementById("more-menu-wrapper");

        btn?.addEventListener("click", (e) => {
          e.stopPropagation();
          const isOpen = document.getElementById("more-dropdown")?.classList.contains("hidden") === false;
          isOpen ? closeMoreMenu() : openMoreMenu();
        });

        // close on outside click
        document.addEventListener("click", (e) => {
          if (!wrapper?.contains(e.target as Node)) closeMoreMenu();
        });

        // close on Escape
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") closeMoreMenu();
        });
      }

      // ── Mobile sidebar ────────────────────────────────────────────────────
      function setupMobileSidebar() {
        const toggle = document.getElementById("sidebar-toggle");
        const overlay = document.getElementById("mobile-overlay");
        const backdrop = document.getElementById("mobile-backdrop");
        const closeBtn = document.getElementById("sidebar-close");

        const open = () => {
          overlay?.classList.remove("hidden");
          toggle?.setAttribute("aria-expanded", "true");
        };
        const close = () => {
          overlay?.classList.add("hidden");
          toggle?.setAttribute("aria-expanded", "false");
        };

        toggle?.addEventListener("click", open);
        backdrop?.addEventListener("click", close);
        closeBtn?.addEventListener("click", close);
        document.getElementById("mobile-sidebar")?.querySelectorAll("a[data-nav-href]").forEach((a) => {
          a.addEventListener("click", close);
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !overlay?.classList.contains("hidden")) close();
        });
      }

      // ── LLM copy ──────────────────────────────────────────────────────────
      async function copyLLMs() {
        try {
          const text = await fetch("/llms.txt").then((r) => r.text());
          await navigator.clipboard.writeText(text);
          return true;
        } catch (_) { return false; }
      }

      function setupLLMCopyButton() {
        // desktop
        const btn = document.getElementById("llm-copy-btn");
        const copyIcon = document.getElementById("llm-copy-icon");
        const checkIcon = document.getElementById("llm-check-icon");
        const label = document.getElementById("llm-copy-label");

        btn?.addEventListener("click", async () => {
          if (await copyLLMs()) {
            copyIcon?.classList.add("hidden");
            checkIcon?.classList.remove("hidden");
            if (label) label.textContent = "Copied!";
            setTimeout(() => {
              copyIcon?.classList.remove("hidden");
              checkIcon?.classList.add("hidden");
              if (label) label.textContent = "LLMs";
            }, 2000);
          }
        });

        // mobile
        const btnM = document.getElementById("llm-copy-btn-mobile");
        const copyIconM = document.getElementById("llm-copy-icon-m");
        const checkIconM = document.getElementById("llm-check-icon-m");
        const labelM = document.getElementById("llm-copy-label-m");

        btnM?.addEventListener("click", async () => {
          if (await copyLLMs()) {
            copyIconM?.classList.add("hidden");
            checkIconM?.classList.remove("hidden");
            if (labelM) labelM.textContent = "Copied!";
            setTimeout(() => {
              copyIconM?.classList.remove("hidden");
              checkIconM?.classList.add("hidden");
              if (labelM) labelM.textContent = "Copy for LLMs";
              closeMoreMenu();
            }, 1500);
          }
        });
      }

      // ── Customizer toggle ─────────────────────────────────────────────────
      function setupCustomizerToggle() {
        const dispatch = () => window.dispatchEvent(new CustomEvent("almach-customizer-toggle"));
        document.getElementById("customizer-toggle")?.addEventListener("click", dispatch);
        document.getElementById("customizer-toggle-mobile")?.addEventListener("click", () => {
          closeMoreMenu();
          dispatch();
        });
      }

      // ── Restore theme after page swap ─────────────────────────────────────
      function restoreTheme() {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const dark = stored === "dark" || (!stored && prefersDark);
        document.documentElement.classList.toggle("dark", dark);
        applyCustomTheme(dark);
      }

      function setup() {
        setupThemeToggle();
        setupMoreMenu();
        setupMobileSidebar();
        setupCustomizerToggle();
        setupLLMCopyButton();
      }

      setup();
      document.addEventListener("astro:after-swap", () => {
        restoreTheme();
        setup();
      });
    </script>
  </body>
</html>
