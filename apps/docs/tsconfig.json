{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@almach/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@almach/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@almach/forms": [
        "../../packages/forms/src/index.ts"
      ],
      "@almach/query": [
        "../../packages/query/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "astro.config.mjs"
  ]
}