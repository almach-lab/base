{
  "name": "@almach/query",
  "version": "0.1.0",
  "description": "TanStack Query utilities for Based UI — queries, mutations, server actions",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@almach/utils": "workspace:*",
    "@tanstack/react-query": "^5.67.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almach-lab/base",
    "directory": "packages/query"
  }
