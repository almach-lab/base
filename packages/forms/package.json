{
  "name": "@almach/forms",
  "version": "4.0.0",
  "description": "Form handling with TanStack Form and Zod validation for Based UI",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-esm.js dist",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@almach/ui": "*",
    "@almach/utils": "*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@almach/ui": "workspace:*",
    "@almach/utils": "workspace:*",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almach-lab/base",
    "directory": "packages/forms"
  },
  "contributors": [
    {
      "name": "rafaalrazzak",
      "url": "https://github.com/rafaalrazzak"
    }
  ]
}
