{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    // ── Strict type-checking ──────────────────────────────────────────────
    "strict": true, // Enables all strict flags
    "exactOptionalPropertyTypes": true, // Prevents assigning `undefined` to optional props
    "noUncheckedIndexedAccess": true, // Array/index access returns T | undefined
    "noImplicitReturns": true, // All code paths must return a value
    "noFallthroughCasesInSwitch": true, // Prevents accidental switch fall-through
    "noImplicitOverride": true, // Class overrides must use `override` keyword
    // ── Module resolution ─────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    // ── Output ────────────────────────────────────────────────────────────
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true
  }
}
