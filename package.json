{
  "name": "based",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "bun run llms:snapshot:check && turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "docs": "bun run --cwd apps/docs dev",
    "deploy": "bun run --cwd apps/docs deploy",
    "release": "bash scripts/release.sh",
    "llms:snapshot:update": "node scripts/generate-llm-ui-snapshot.mjs",
    "llms:snapshot:check": "node scripts/generate-llm-ui-snapshot.mjs --check",
    "postinstall": "node scripts/fix-esm.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.2.0"
  }
}
