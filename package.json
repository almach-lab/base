{
  "name": "based",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run build:packages && bun run build:docs",
    "build:packages": "bun run --filter @almach/utils build && bun run --filter @almach/ui build && bun run --filter @almach/forms build && bun run --filter @almach/query build",
    "build:docs": "bun run --filter docs build",
    "dev": "bun run --workspaces --if-present dev",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "typecheck": "bun run llms:snapshot:check && bun run build:packages && bun run --workspaces --if-present typecheck",
    "clean": "bun run --workspaces --if-present clean && rm -rf node_modules",
    "docs": "bun run --cwd apps/docs dev",
    "deploy": "bun run --cwd apps/docs deploy",
    "release": "bash scripts/release.sh",
    "release:publish-env": "node scripts/publish-from-env.mjs",
    "release:reset-baseline": "node scripts/reset-release-baseline.mjs",
    "release:reset-remote": "node scripts/reset-remote-releases.mjs",
    "llms:snapshot:update": "node scripts/generate-llm-ui-snapshot.mjs",
    "llms:snapshot:check": "node scripts/generate-llm-ui-snapshot.mjs --check",
    "postinstall": "node scripts/fix-esm.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.2.0"
  }
}
